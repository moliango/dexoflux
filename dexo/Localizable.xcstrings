    "cloudflare.verify.instructions" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Complete the Cloudflare check in this page. When cf_clearance is detected, Dexo will sync it for native requests."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在此页面完成 Cloudflare 验证。检测到 cf_clearance 后，Dexo 会同步给原生请求使用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在此頁面完成 Cloudflare 驗證。檢測到 cf_clearance 後，Dexo 會同步給原生請求使用。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在此頁面完成 Cloudflare 驗證。檢測到 cf_clearance 後，Dexo 會同步給原生請求使用。"
          }
        }
      }
    },
