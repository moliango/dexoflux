          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在此頁面完成 Cloudflare 驗證。檢測到 cf_clearance 後，Dexo 會同步給原生請求使用。"
          }
        }
      }
