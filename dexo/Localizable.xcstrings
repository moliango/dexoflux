    "settings.data.clear_all.confirm.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This clears image cache, local profile cache, emoji cache, and login cookies. You may need to log in or pass Cloudflare verification again."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将清除图片缓存、本地个人资料缓存、Emoji 缓存和登录 Cookie。之后可能需要重新登录或重新通过 Cloudflare 验证。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將清除圖片快取、本機個人資料快取、Emoji 快取和登入 Cookie。之後可能需要重新登入或重新通過 Cloudflare 驗證。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
